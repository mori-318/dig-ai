GEMINI_API_KEY=""

# redis関連
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""

# MySQL関連
# Docker Compose起動時は、MYSQL_HOST / MYSQL_USER / MYSQL_PASSWORD が
# docker-compose.yml の environment で上書きされます。
# ローカル直実行（uv run ...）では下記を環境に合わせて設定してください。
MYSQL_HOST="localhost"
MYSQL_PORT=3306
MYSQL_USER="root"
MYSQL_PASSWORD=""
MYSQL_DATABASE=""
